# ═══════════════════════════════════════════════════════
#  Central de Tarefas — exemplo de variáveis de ambiente
#  Copie para .env.local e preencha com seus valores.
# ═══════════════════════════════════════════════════════

# ── Supabase (Backend Node) ──────────────────────────────
SUPABASE_URL=http://SEU_IP:54321
SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# ── Supabase (Frontend Vite) ─────────────────────────────
VITE_SUPABASE_URL=http://SEU_IP:54321
VITE_SUPABASE_ANON_KEY=sua_anon_key

# ── API URL (vazio = same-origin) ────────────────────────
VITE_API_URL=

# ── Backend Node (API) em dev ─────────────────────────────
# Proxy do Vite (/api) → este host:porta (API Node, porta BACKEND_PORT; não é Supabase :54321).
# Padrão do host no Vite: 127.0.0.1. Se o Express só for acessível pelo IP da LAN, defina:
#   BACKEND_HOST=192.168.x.x
# URL completa (opcional) sobrescreve BACKEND_HOST + BACKEND_PORT:
#   BACKEND_DEV_URL=http://192.168.x.x:3002
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3002
BACKEND_DEV_URL=
# Alias opcional igual a BACKEND_DEV_URL (só para quem prefere prefixo VITE_)
VITE_API_PROXY_TARGET=

# ── Convite de usuario (admin cria conta no Supabase Auth) ─
# Obrigatorio para POST /api/users/with-auth. Min. 6 caracteres no backend; use senha forte em producao.
# Nao commite valor real. O usuario troca na tela de login (fluxo primeiro acesso).
MANUAL_INVITE_TEMP_PASSWORD=

# ── Ollama (opcional) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── URLs públicas ────────────────────────────────────────
NEXT_PUBLIC_FRONTEND_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=http://SEU_IP:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key

# ── GitHub (opcional) ────────────────────────────────────
GITHUB_TOKEN=seu_github_pat
