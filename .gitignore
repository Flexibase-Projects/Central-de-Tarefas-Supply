# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────────
build/
dist/
*.tsbuildinfo

# ── Environment & secrets (NEVER commit these) ────────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
backend/.env
backend/.env.local
frontend/.env
frontend/.env.local

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing & coverage ────────────────────────────────────────
coverage/
.nyc_output/

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Cursor / Claude (IDE tools) ───────────────────────────────
.cursor/
.claude/

# ── Temporary / misc ──────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak

# ── Loose image files in repo root (use /public instead) ──────
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
# Exception: keep the actual project logo
!/LOGO.png
